<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ModalHllController">
   <children>
      <Label prefHeight="18.0" prefWidth="600.0" text="Criação Novo Hyperloglog" textAlignment="JUSTIFY">
         <font>
            <Font name="Linux Libertine Bold" size="13.0" />
         </font>
      </Label>
      <Label prefHeight="18.0" prefWidth="600.0" text="Nome:" textAlignment="JUSTIFY">
         <font>
            <Font name="Linux Libertine Bold" size="13.0" />
